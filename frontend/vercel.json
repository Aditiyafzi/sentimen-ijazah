{
  "buildCommand": "npm ci && npx vite build",
  "outputDirectory": "dist",
  "devCommand": "vite",
  "routes": [
    {
      "src": "/assets/.*",
      "dest": "/assets/$1",
      "headers": {
        "Cache-Control": "public, max-age=31536000, immutable"
      }
    },
    {
      "src": "/.*\\.(jpg|jpeg|png|gif|svg|ico|webp)$",
      "dest": "/$1",
      "headers": {
        "Cache-Control": "public, max-age=31536000, immutable"
      }
    },
    {
      "src": "/(.*)",
      "dest": "/index.html",
      "status": 200
    }
  ]
}